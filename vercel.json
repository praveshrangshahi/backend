{
    "version": 2,
    "builds": [
        {
            "src": "src/app.js",
            "use": "@vercel/node"
        }
    ],
    "routes": [
        {
            "src": "/uploads/(.*)",
            "dest": "/api/upload?path=$1"
        },
        {
            "src": "/(.*)",
            "dest": "src/app.js"
        }
    ]
}